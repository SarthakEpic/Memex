# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local
# Note: .env.example IS committed (it's the template, no secrets)

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/

# Database (contains personal notes, emails, chat history — DO NOT commit)
/db/*.db
/db/*.db-journal

# Mini-services (separate node projects)
/mini-services/*/node_modules
/mini-services/*/.env*

# Agent context
/agent-ctx/

# Watchdog logs
/tmp/watchdog*.log