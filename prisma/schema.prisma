// Memex — citation-first knowledge retrieval for personal Markdown notes
// Adapted to sandbox stack: Next.js + Prisma/SQLite + z-ai-web-dev-sdk

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notes & chunks (the atomic unit of retrieval)
// ─────────────────────────────────────────────────────────────────────────────

model Note {
  id          String   @id @default(cuid())
  title       String
  content     String
  sourcePath  String   @unique // e.g. /notes/databases.md
  project     String   @default("general")
  tags        String   @default("") // comma-separated
  contentHash String   // sha256, used for change detection
  chunkCount  Int      @default(0)
  pinned      Boolean  @default(false) // user-pinned notes sort to top
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chunks    Chunk[]
  decisions Decision[]

  @@index([project])
  @@index([createdAt])
  @@index([pinned])
}

model Chunk {
  id           String   @id @default(cuid())
  noteId       String
  note         Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  chunkIndex   Int
  text         String
  headingPath  String   @default("") // e.g. "Databases > Postgres vs Mongo"
  tokens       Int      @default(0)
  // Precomputed term frequencies for BM25 (JSON map: {term: count})
  termFreq     String   @default("{}")
  createdAt    DateTime @default(now())

  decisions Decision[]

  @@unique([noteId, chunkIndex])
  @@index([noteId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Decisions (LLM-extracted)
// ─────────────────────────────────────────────────────────────────────────────

model Decision {
  id           String   @id @default(cuid())
  noteId       String
  note         Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  chunkId      String
  chunk        Chunk    @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  title        String
  decisionDate String   @default("") // ISO date or empty
  rationale    String
  alternatives String   @default("") // pipe-separated
  outcome      String   @default("")
  participants String   @default("") // pipe-separated
  project      String   @default("general")
  confidence   Float    @default(0.8) // 0..1 LLM self-reported
  pinned       Boolean  @default(false) // user-pinned decisions sort to top
  createdAt    DateTime @default(now())

  @@index([project])
  @@index([decisionDate])
  @@index([pinned])
}

// ─────────────────────────────────────────────────────────────────────────────
// Chat sessions & messages (with inline citations)
// ─────────────────────────────────────────────────────────────────────────────

model ChatSession {
  id        String   @id @default(cuid())
  title     String   @default("New chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // 'user' | 'assistant'
  content   String
  // JSON array of {chunkId, noteId, sourcePath, chunkIndex, snippet, score}
  citations String   @default("[]")
  createdAt DateTime @default(now())

  @@index([sessionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Email integration (simulated SMTP — stored in DB with status pipeline)
// ─────────────────────────────────────────────────────────────────────────────

model Email {
  id         String   @id @default(cuid())
  toAddress  String
  fromName   String   @default("Memex")
  subject    String
  bodyMarkdown String // markdown body
  bodyHtml   String   @default("") // rendered html (computed on send)
  status     String   @default("draft") // draft | pending_verification | queued | scheduled | sending | sent | delivered | failed | cancelled
  sourceType String   @default("manual") // manual | chat | decision | note | digest | ai
  sourceId   String   @default("")
  errorMessage String @default("")
  queuedAt   DateTime @default(now())
  scheduledFor DateTime?
  sentAt     DateTime?
  deliveredAt DateTime?
  // Enhanced tracking
  isAiGenerated Boolean @default(false) // true if AI drafted this email
  verified      Boolean @default(false) // true if human verification completed
  attempts      Int     @default(0) // number of send attempts
  lastAttemptAt DateTime?

  @@index([status])
  @@index([sourceType])
  @@index([queuedAt])
  @@index([scheduledFor])
  @@index([isAiGenerated])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String   // digest | brief | snapshot | custom
  subject   String
  bodyMarkdown String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Email Account Connection (IMAP/SMTP settings for inbox management)
// ─────────────────────────────────────────────────────────────────────────────

model EmailAccount {
  id          String   @id @default(cuid())
  emailAddress String  @unique
  displayName String   @default("")
  // IMAP settings (for receiving)
  imapHost    String   @default("")
  imapPort    Int      @default(993)
  imapUser    String   @default("")
  imapSecure  Boolean  @default(true)
  imapPassword String  @default("") // app-specific password (encrypted in production)
  // SMTP settings (for sending)
  smtpHost    String   @default("")
  smtpPort    Int      @default(587)
  smtpUser    String   @default("")
  smtpSecure  Boolean  @default(true)
  smtpPassword String  @default("")
  // Status
  connected   Boolean  @default(false)
  lastSyncAt  DateTime?
  syncMode    String   @default("demo") // "demo" = simulated, "real" = real IMAP
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Inbox Email (received emails with AI analysis)
// ─────────────────────────────────────────────────────────────────────────────

model InboxEmail {
  id           String   @id @default(cuid())
  accountId    String   @default("") // reference to EmailAccount
  fromAddress  String
  fromName     String   @default("")
  toAddress    String
  subject      String
  body         String   // plain text body
  bodyHtml     String   @default("")
  // AI analysis
  category     String   @default("normal") // urgent | important | normal | newsletter | spam
  action       String   @default("review") // reply_needed | review | archive | unsubscribe
  summary      String   @default("") // AI one-sentence summary
  keyPoints    String   @default("[]") // JSON array of key points
  suggestedReply String @default("") // AI draft reply
  analyzed     Boolean  @default(false)
  // Thread
  threadId     String   @default("") // groups emails in same conversation
  inReplyTo    String   @default("") // message ID this replies to
  // Status
  isRead       Boolean  @default(false)
  isStarred    Boolean  @default(false)
  isArchived   Boolean  @default(false)
  receivedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([category])
  @@index([action])
  @@index([isRead])
  @@index([receivedAt])
  @@index([threadId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Profile — single demo user + email settings
// ─────────────────────────────────────────────────────────────────────────────

model Profile {
  id            String   @id @default("me")
  email         String   @default("you@memex.local")
  name          String   @default("Memex User")
  smtpHost      String   @default("smtp.memex.local")
  smtpPort      Int      @default(587)
  smtpUser      String   @default("")
  dailyDigest   Boolean  @default(true)
  digestHour    Int      @default(9) // hour of day for digest
  // Security settings
  dataEncryption Boolean  @default(true)
  llmPrivacyMode Boolean  @default(true) // only send minimal context to LLM
  autoDeleteDays Int      @default(0) // 0 = never auto-delete
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
